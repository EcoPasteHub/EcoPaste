{
  "$schema": "../gen/schemas/desktop-schema.json",
  "description": "Base capability shared by all app windows: core window/event/app APIs only. Platform-specific grants live in separate capabilities.",
  "identifier": "default",
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "log:default",
    "os:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "opener:default",
    "core:window:deny-internal-toggle-maximize",
    "core:window:allow-hide"
  ],
  "windows": ["*"]
}
