{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*"],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    },
    "windows": [
      {
        "acceptFirstMouse": true,
        "alwaysOnTop": true,
        "decorations": false,
        "height": 600,
        "label": "main",
        "maximizable": false,
        "minHeight": 600,
        "minWidth": 360,
        "skipTaskbar": true,
        "title": "EcoPaste",
        "transparent": true,
        "url": "index.html/#/",
        "visible": false,
        "width": 360
      },
      {
        "acceptFirstMouse": true,
        "center": true,
        "height": 600,
        "hiddenTitle": true,
        "label": "preference",
        "maximizable": false,
        "minHeight": 600,
        "minWidth": 900,
        "scrollBarStyle": "fluentOverlay",
        "skipTaskbar": true,
        "title": "EcoPaste Preference",
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 15,
          "y": 25
        },
        "url": "index.html/#/preference",
        "visible": false,
        "width": 900
      }
    ]
  },
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["assets/tray.ico"],
    "shortDescription": "EcoPaste",
    "targets": ["nsis", "dmg", "app"]
  },
  "identifier": "com.ayangweb.eco-paste",
  "productName": "EcoPaste",
  "version": "../package.json"
}
