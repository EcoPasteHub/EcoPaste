{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*"],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    },
    "windows": [
      {
        "acceptFirstMouse": true,
        "alwaysOnTop": true,
        "decorations": false,
        "focusable": false,
        "height": 600,
        "label": "main",
        "maximizable": false,
        "minHeight": 600,
        "minWidth": 360,
        "skipTaskbar": true,
        "title": "EcoPaste",
        "transparent": true,
        "url": "index.html/#/",
        "visible": false,
        "width": 360
      }
    ]
  },
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "description": "EcoPaste history backup",
        "exportedType": {
          "conformsTo": ["public.data"],
          "identifier": "com.ayangweb.eco-paste.backup"
        },
        "ext": ["ecopastebak"],
        "mimeType": "application/vnd.ecopaste.backup",
        "name": "EcoPaste Backup",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["assets/tray.ico"],
    "shortDescription": "EcoPaste",
    "targets": ["nsis", "dmg", "app"]
  },
  "identifier": "com.ayangweb.eco-paste",
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/EcoPasteHub/EcoPaste/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwMzUzRkJCQUI3NjY4RgpSV1NQWnJlNisxTURBbFE2WWJpUlBJR0x0OXJOclVuUGlVYVhoNjJPZitYN0Q4V05GeW1aU2w0Zwo=",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "productName": "EcoPaste",
  "version": "../package.json"
}
