{
  "name": "eco-paste",
  "private": true,
  "version": "1.0.0",
  "description": "A local-first clipboard manager for macOS and Windows.",
  "author": "ayangweb",
  "license": "Apache-2.0",
  "homepage": "https://github.com/EcoPasteHub/EcoPaste#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EcoPasteHub/EcoPaste.git"
  },
  "bugs": {
    "url": "https://github.com/EcoPasteHub/EcoPaste/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "run-s build:icon dev:vite",
    "build": "run-s tsc build:*",
    "tsc": "tsc --noEmit",
    "dev:vite": "vite",
    "build:icon": "tsx scripts/buildIcon.ts",
    "build:vite": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "release": "release-it --verbose",
    "release-beta": "release-it --verbose --preRelease=beta --preReleaseBase=1",
    "release-rc": "release-it --verbose --preRelease=rc --preReleaseBase=1",
    "lint": "biome check",
    "format": "biome check --write",
    "prepare": "simple-git-hooks",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-os": "^2.3.2",
    "ahooks": "^3.9.7",
    "antd": "^6.5.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "i18next": "^26.3.3",
    "motion": "^12.42.0",
    "overlayscrollbars": "^2.16.0",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router": "^7.18.0",
    "react-virtuoso": "^4.18.10",
    "tailwind-merge": "^3.6.0",
    "tauri-plugin-macos-permissions-api": "2.3.0",
    "valtio": "^2.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@iconify-json/lets-icons": "^1.2.2",
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/ph": "^1.2.2",
    "@release-it/bumper": "^7.0.6",
    "@release-it/conventional-changelog": "^11.0.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "release-it": "^20.2.1",
    "sass": "^1.101.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "unocss": "^66.7.3",
    "vite": "^7.3.6"
  },
  "simple-git-hooks": {
    "commit-msg": "npx --no-install commitlint -e",
    "pre-commit": "npx lint-staged"
  }
}
