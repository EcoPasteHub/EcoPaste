{
  "name": "eco-paste",
  "private": true,
  "version": "0.6.0-beta.3",
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "run-s build:icon dev:vite",
    "build": "run-s tsc build:*",
    "tsc": "tsc --noEmit",
    "dev:vite": "vite",
    "build:icon": "tsx scripts/buildIcon.ts",
    "build:vite": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "biome check",
    "format": "biome check --write",
    "prepare": "simple-git-hooks",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.4.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-os": "^2.3.2",
    "ahooks": "^3.9.7",
    "antd": "^6.4.3",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.8",
    "i18next": "^26.3.1",
    "motion": "^12.40.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-router": "^7.16.0",
    "react-virtuoso": "^4.18.7",
    "tailwind-merge": "^3.6.0",
    "valtio": "^2.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@iconify-json/lets-icons": "^1.2.2",
    "@iconify-json/lucide": "^1.2.111",
    "@iconify-json/ph": "^1.2.2",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "lint-staged": "^17.0.7",
    "npm-run-all": "^4.1.5",
    "sass": "^1.100.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "unocss": "^66.7.0",
    "vite": "^7.3.3"
  },
  "simple-git-hooks": {
    "commit-msg": "npx --no-install commitlint -e",
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
