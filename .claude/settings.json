{
  "enabledPlugins": {},
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/inject-subagent-context.py",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Task"
      },
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/inject-subagent-context.py",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Agent"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/session-start.py",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "startup"
      },
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/session-start.py",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "clear"
      },
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/session-start.py",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "compact"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 .claude/hooks/inject-workflow-state.py",
            "timeout": 15,
            "type": "command"
          }
        ]
      }
    ]
  }
}
